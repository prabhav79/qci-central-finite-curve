# Copy to .env (gitignored) for local development, or set directly as shell env vars.
# All values below are placeholders.

ENVIRONMENT=local
LOG_LEVEL=INFO

# Railway will inject these automatically when the backend service is linked to
# the Postgres and Redis services. Override locally by pointing at docker-compose.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/qci
REDIS_URL=redis://localhost:6379/0

# Google AI Studio (Gemini Flash — free tier is fine for Phase 0)
GEMINI_API_KEY=your_google_ai_studio_key_here

# RunPulse (OCR / schema extraction)
RUNPULSE_API_KEY=your_runpulse_key_here

# Demo-tier auth (replaced by SSO in Phase 3)
DEMO_PASSWORD=change-me-before-sharing-the-demo
JWT_SECRET=generate-a-long-random-string-here
JWT_TTL_MINUTES=60

# CORS origin for the Next.js frontend
FRONTEND_ORIGIN=http://localhost:3000

# Blob storage (Phase 0: Railway volume mount; Phase 3: S3-compatible)
BLOB_BASE_PATH=/data/blobs
