# Keep the build context lean and reproducible.

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual envs
.venv/
venv/
env/

# Git / VCS
.git/
.github/
.gitignore
.gitattributes

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
*.log

# Secrets / env
.env
.env.local
.env.*.local

# Railway / Warp metadata
.railway/
.warp/

# Phase 0: the existing 24 PDFs + their processed JSONs ship with the image
# because the container's filesystem is the Phase 0 blob store (see backend/storage/blob.py).
# Swap to S3 in Phase 3 and these get excluded.
#   Work Orders/
#   static/
#   data/processed/
data/extracted_text/
data/raw/
data/quarantine/
data/temp/
data/temp_images/
*.docx
*.xlsx

# Node / Next.js (frontend has its own image)
frontend/node_modules/
frontend/.next/
frontend/out/
node_modules/

# Tests & examples
tests/
docs/
examples/

# Local dev helpers
docker-compose*.yml
*.md
!README.md
